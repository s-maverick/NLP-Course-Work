put_attentions=False\n","    )\n","    decoded_reasoning_output = reasoning_tokenizer.decode(reasoning_outputs[0, reasoning_inputs[\"input_ids\"].shape[-1]:], skip_special_tokens=False)\n","\n","    # Generate output using base_model\n","    base_inputs = base_tokenizer.apply_chat_template(\n","        messages,\n","        add_generation_prompt=True,\n","        return_dict=True,\n","        return_tensors=\"pt\",\n","    )\n","    base_outputs = base_model.generate(\n","        **base_inputs.to(base_model.device),\n","        max_new_tokens=max_new_tokens_value,\n","        temperature=temperature_value,\n","        top_p=top_p_value,\n","        do_sample=True,\n","        output_attentions=False\n","    )\n","    decoded_base_output = base_tokenizer.decode(base_outputs[0, base_inputs[\"input_ids\"].shape[-1]:], skip_special_tokens=False)\n","\n","\n","    rprint(f\"[bold blue]Question:[/bold blue] {question}\")\n","    rprint(f\"[bold green]Reasoning Model Output:[/bold green]\\n{decoded_reasoning_output}\\n{'-'*25}\")\n","    rprint(f\"[bold orange]Base Model Output:[/bold orange]\\n{decoded_base_output}\\n{'-'*50}\")"],"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["## Compare reasoning and base models\n","The goal of this section is to identify scenarios in which reasoning models outperform or underperform non-reasoning models and to inspect the model's reasoning.\n","\n","You can use the interface below to experiment with some pre-set prompts and try out your own prompts."],"metadata":{"id":"mLRJjvzQVfE8"}},{"cell_type":"code","metadata":{"id":"fcaac46a","cellView":"form"},"source":["# @title Experiment with different prompts\n","# @markdown Experiment with different prompts to observe the difference between reasoning and non-reasoning models. This might take 1-2 minutes to finish generating outputs.\n","from rich.table import Table\n","import ipywidgets as widgets\n","from IPython.display import display, HTML\n","from tqdm.notebook import tqdm # Import tqdm for progress bar\n","\n","# Pre-selected prompts\n","PRESELECTED_PROMPTS = {\n","    \"Select a prompt\": \"\", # Default empty option\n","    # both models work\n","    \"1 - Easy math problem\": \"Betty is saving money for a new wallet which costs $100. Betty has only half of the money she needs. Her parents decided to give her $15 for that purpose, and her grandparents twice as much as her parents. How much more money does Betty need to buy the wallet?\",\n","    # base model work and reasoning model spends too many tokens thinking\n","    \"2 - Constrained language generation\": \"Please describe Seattle with sentences that only contain words that start with an S. No other words allowed!\",\n","    # base model does not work\n","    \"3 - Cause and effect\": \"\"\"Which event caused the other?\n","    Event A: It started raining.\n","    Event B: The driver turned the wipers on.\"\"\",\n","    \"Try your own\": \"\" # Option for free text input\n","}\n","\n","# Group and display the widgets\n","generation_parameters_widget = widgets.VBox([max_new_tokens_widget, temperature_widget, top_p_widget])\n","display(generation_parameters_widget)\n","\n","prompt_dropdown = widgets.Dropdown(\n","    options=list(PRESELECTED_PROMPTS.keys()),\n","    description='Choose Prompt:',\n","    disabled=False,\n","    style={'description_width': 'initial'}\n",")\n","\n","\n","prompt_input = widgets.Textarea(\n","    value=PRESELECTED_PROMPTS[prompt_dropdown.value],\n","    placeholder='Enter your prompt here',\n","    description='Prompt:',\n","    disabled=False,\n","    layout=widgets.Layout(width='80%', height='100px')\n",")\n","\n","output_area = widgets.Output()\n","\n","def update_prompt_input(*args):\n","    \"\"\"Updates the prompt_input textarea based on the dropdown selection.\"\"\"\n","    if prompt_dropdown.value == \"Try your own\":\n","        prompt_input.value = \"\" # Clear for free text\n","        prompt_input.disabled = False\n","    else:\n","        prompt_input.value = PRESELECTED_PROMPTS[prompt_dropdown.value]\n","        prompt_input.disabled = False # Enable in case it was disabled\n","\n","\n","def generate_and_display_outputs(sender):\n","    with output_area:\n","        output_area.clear_output()\n","        prompt = prompt_input.value\n","\n","        if not prompt:\n","            rprint(\"[bold red]Please enter a prompt.[/bold red]\")\n","            return\n","\n","        messages = [{\n","            \"role\": \"user\",\n","            \"content\": prompt\n","        }]\n","\n","        # Get values from the widgets\n","        max_new_tokens_value = max_new_tokens_widget.value\n","        temperature_value = temperature_widget.value\n","        top_p_value = top_p_widget.value\n","\n","        # Create a progress bar\n","        progress_bar = tqdm(total=2, desc=\"Generating Model Outputs\")\n","        display(progress_bar.container) # Display the progress bar\n","\n","        # Generate output using reasoning_model\n","        reasoning_inputs = reasoning_tokenizer.apply_chat_template(\n","            messages,\n","            add_generation_prompt=True,\n","            return_dict=True,\n","            return_tensors=\"pt\",\n","        )\n","        reasoning_outputs = reasoning_model.generate(\n","            **reasoning_inputs.to(reasoning_model.device),\n","            max_new_tokens=max_new_tokens_value,\n","            temperature=temperature_value,\n","            top_p=top_p_value,\n","            do_sample=True,\n","            output_attentions=False\n","        )\n","        decoded_reasoning_output = reasoning_tokenizer.decode(reasoning_outputs[0, reasoning_inputs[\"input_ids\"].shape[-1]:], skip_special_tokens=False)\n","        progress_bar.update(1) # Update progress after reasoning model\n","\n","        # Generate output using base_model\n","        base_inputs = base_tokenizer.apply_chat_template(\n","            messages,\n","            add_generation_prompt=True,\n","            return_dict=True,\n","            return_tensors=\"pt\",\n","        )\n","        base_outputs = base_model.generate(\n","            **base_inputs.to(base_model.device),\n","            max_new_tokens=max_new_tokens_value,\n","            temperature=temperature_value,\n","            top_p=top_p_value,\n","            do_sample=True,\n","            output_attentions=False\n","        )\n","        decoded_base_output = base_tokenizer.decode(base_outputs[0, base_inputs[\"input_ids\"].shape[-1]:], skip_special_tokens=False)\n","        progress_bar.update(1) # Update progress after base model\n","        progress_bar.close() # Close the progress bar when done\n","\n","        # Create and display table\n","        table = Table(title=f\"Compare Reasoning Model and Base Model Output (max new tokens = {max_new_tokens_value})\")\n","        table.add_column(\"[bold green]Reasoning Model Output[/bold green]\", style=\"green\")\n","        table.add_column(\"[bold blue]Base Model Output[/bold blue]\", style=\"blue\")\n","\n","        table.add_row(decoded_reasoning_output, decoded_base_output)\n","\n","        rprint(table)\n","\n","submit_prompt_button = widgets.Button(description=\"Generate Outputs\")\n","submit_prompt_button.on_click(generate_and_display_outputs)\n","\n","# Observe changes in the dropdown\n","prompt_dropdown.observe(update_prompt_input, names='value')\n","\n","display(widgets.VBox([prompt_dropdown, prompt_input, submit_prompt_button, output_area]))\n","update_prompt_input() # Initialize the prompt_input with the default dropdown value"],"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["### 🔍 Q5: Reasoning Behavior Analysis Questions"],"metadata":{"id":"5lh89STilGVB"}},{"cell_type":"markdown","source":["5.1) When did the reasoning model perform better, worse, or the same as the base model? Comment on the models' behaviors when using the pre-selected prompts."],"metadata":{"id":"6iwjQCGlSYz7"}},{"cell_type":"markdown","source":["**Answer**\n","\n","\n","When I compared the reasoning model with the base model across the pre-selected prompts, each one showed different strengths depending on the type of task.\n","\n","For the Math / Logic Task (Betty’s Wallet Problem), the reasoning model walked through the entire process step by step. It explained how half of 100 is 50, then added the contributions from her parents (15) and grandparents (30) to get 95, and finally subtracted 95 from 100 to find 5. It even took a moment to confirm that “half of the money she needs” was being interpreted correctly. The base model reached the exact same answer—5—but handled it in a much faster, compressed way, simply laying out the arithmetic (100÷2=50, 50+15+30=95, 100−95=5) without the step-by-step thinking. Both were correct, but the reasoning model emphasized clarity, while the base model emphasized efficiency.\n","\n","For the Constrained Creative Task (“Describe Seattle Using Only Words Starting with S”), the difference between the two models was much more noticeable. The reasoning model got tangled in its own analysis. It kept checking every word, worrying about grammar, and revising repeatedly, but it never actually delivered a clean, fully constrained answer. The base model, on the other hand, produced a smooth, alliterative description—“Seattle shines spectacularly, stunningly serene, splendidly splendid …”—and successfully kept every word starting with “S.” In this case, the base model clearly performed better because it focused on generating the output instead of overthinking the constraints.\n","\n","For the Cause-and-Effect Task (“Rain and Wipers”), both models again ended up with the same correct conclusion. The reasoning model thoroughly examined both possible directions of causation, identified why wipers cannot cause rain, and concluded that the onset of rain (Event A) led the driver to turn on the wipers (Event B). The base model delivered the same result but in a short, direct explanation: rain caused the driver to turn on the wipers. The reasoning model was more explicit about its logic, while the base model simply presented the correct relationship.\n","\n","The reasoning model tended to perform better when step-by-step analysis added value, worse when overthinking got in the way of creative output, and about the same as the base model when the task was straightforward and didn’t require extended reasoning.\n"],"metadata":{"id":"IUiiGzbBSc9v"}},{"cell_type":"markdown","source":["5.2) Try your own prompt and comment on the behavior you observe. Be creative!"],"metadata":{"id":"Awc_QksxSm5N"}},{"cell_type":"markdown","source":["**Answer**\n","\n","When I tried my own prompt—**“Give updates about GTA VI”**—the two models behaved very differently, and the contrast made their strengths really obvious.\n","\n","The reasoning model spent most of its effort talking itself through the problem. It went into a long internal monologue about Rockstar Games, possible release years, rumors about engines, E3 announcements, leaked concept art, and even hypothetical beta tests. But it never actually *gave* me a straightforward update. Instead, it overanalyzed every angle—what it remembered, what it wasn’t sure about, what might be rumors, what sources normally say—before finally summarizing everything in a very cautious, qualified way. The output felt extremely careful and reflective, but also slow and full of speculation-management rather than useful information.\n","\n","The base model, in contrast, answered the prompt directly and cleanly. It simply said that as of October 2023, Rockstar had not officially announced anything about GTA VI, and encouraged checking official sources like Rockstar Newswire or gaming outlets. It didn't wander, didn't speculate, and didn’t waste time. It delivered a short, factual, and practical response.\n","\n","Comparing the two:\n","\n","* The reasoning model **overthinks** in a situation where the user probably just wants a clear update. It tries to reason through rumors and possibilities, but ends up with a long, meandering thought process.\n","* The base model **sticks to what is known**, avoids unnecessary speculation, and gives a concise answer without hesitation.\n","* For this kind of prompt—where information is limited and mostly factual—the base model is more useful because it stays grounded and avoids spiraling into hypotheticals.\n","* The reasoning model is helpful when the task actually requires structured reasoning, but on simple information requests like this, the extra analysis gets in the way.\n","\n","Here, using this prompt showed that the base model handles straightforward, fact-based questions better, while the reasoning model can accidentally “overthink” and drift into long internal explanations that don’t add much value.\n","\n","\n"],"metadata":{"id":"bOrmHZaPSqFW"}},{"cell_type":"markdown","source":["5.3) Read some of the reasoning chains provided by the reasoning model. Do you think the reasoning makes sense and helped the model reach the correct final answer?"],"metadata":{"id":"Zms6ZHGuSuhz"}},{"cell_type":"markdown","source":["**Answer**\n","\n","Yes, the reasoning chains generally make sense, and they clearly helped the model reach the correct final answers. In the Betty’s wallet problem, the model walked through the arithmetic step by step—calculating half of the goal, adding the contributions from her parents and grandparents, and verifying the totals before concluding that she still needed five dollars. That careful breakdown made the reasoning transparent and supported the correct result. In the Seattle “S-only” description, the chain acted more like a planning space. The model checked whether each word followed the constraint, revised phrases when they didn’t fit, and tried to keep the sentence coherent. You can see the model using the reasoning section to strategize around the constraint, even if it sometimes slows itself down by thinking too much. For the rain and wipers example, the reasoning was methodical. The model considered both directions of causation, ruled out the impossible one, and explained why the rain leads the driver to activate the wipers. The chain shows the model validating its conclusion rather than just giving an answer.\n","\n","Across these tasks, the reasoning space functions like a scratchpad: for math and logic, it breaks the problem into smaller checks; for creative or constraint-based tasks, it identifies the challenge and plans a path around it. Overall, the reasoning chains are consistent and purposeful, and they genuinely help the model move from an initial idea to the correct final answer.\n"],"metadata":{"id":"dODnG0PXS17v"}},{"cell_type":"markdown","source":["## AI Disclosure\n","\n","*   Did you use any AI assistance to complete this homework? If so, please also specify what AI you used.\n","    * No\n","\n","\n","---\n","*(only complete the below questions if you answered yes above)*\n","\n","*   If you used a large language model to assist you, please paste *all* of the prompts that you used below. Add a separate bullet for each prompt, and specify which problem is associated with which prompt.\n","    * *your response here*\n","*   **Free response**: For each problem for which you used assistance, describe your overall experience with the AI. How helpful was it? Did it just directly give you a good answer, or did you have to edit it? Was its output ever obviously wrong or irrelevant? Did you use it to get the answer or check your own answer?\n","    * *your response here*\n"],"metadata":{"id":"hFAYSdttAFNG"}}]}